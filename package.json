    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "form-data": "^4.0.4",
    "image-size": "^2.0.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "stripe": "^20.0.0",
    "xlsx": "^0.18.5"
