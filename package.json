{
  "name": "caspio-pricing-proxy",
  "version": "1.0.0",
  "description": "API Proxy for Caspio Pricing Data",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --config jest.config.js",
    "test:local": "TEST_BASE_URL=http://localhost:3002 jest --config jest.config.js",
    "test:prod": "jest --config jest.config.js",
    "sync-sales": "node scripts/sync-all-sales.js",
    "update-postman": "node scripts/update-postman-collection.js",
    "deploy-status": "node scripts/update-endpoint-status.js",
    "postman-test": "node scripts/postman-api-client.js test",
    "postman-list": "node scripts/postman-api-client.js list",
    "archive-daily-sales": "node scripts/archive-daily-sales.js",
    "reconcile-rep-baseline": "node scripts/reconcile-rep-baseline-from-csv.js",
    "rebuild-rep-archive": "node scripts/rebuild-rep-archive-from-manageorders.js",
    "rebuild-account-ytd": "node scripts/rebuild-account-ytd-from-manageorders.js",
    "archive-garment-tracker": "node scripts/archive-garment-tracker.js",
    "sync-garment-tracker": "node scripts/sync-garment-tracker.js",
    "sync-crm-dashboards": "node scripts/sync-crm-dashboards.js",
    "sync-contacts": "node scripts/sync-contacts.js",
    "sync-sanmar": "node scripts/sync-sanmar.js",
    "sync-manageorders": "node scripts/sync-manageorders.js",
    "sync-commissions": "node scripts/sync-commissions.js",
