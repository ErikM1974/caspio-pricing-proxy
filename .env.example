# .env.example - Template for environment variables
# Copy to .env and fill in your actual values

# Caspio API Configuration
CASPIO_ACCOUNT_DOMAIN=your-account.caspio.com
CASPIO_CLIENT_ID=your-client-id
CASPIO_CLIENT_SECRET=your-client-secret

# SanMar API Configuration
SANMAR_USERNAME=your-sanmar-username
SANMAR_PASSWORD=your-sanmar-password
SANMAR_CUSTOMER_NUMBER=your-sanmar-customer-number

# Supacolor (Codewolf Control) API Configuration
# Provided by Rain at Codewolf on behalf of Mike (Supacolor CEO).
# Used for read-only sync of Supacolor jobs into our Caspio mirror.
SUPACOLOR_CLIENT_ID=your-supacolor-client-id
SUPACOLOR_CLIENT_SECRET=your-supacolor-client-secret
SUPACOLOR_API_BASE_URL=https://api.supacolor.com
SUPACOLOR_OAUTH_URL=https://keycloak-uswest.codewolf.co.nz/realms/sc/protocol/openid-connect/token

# Server Configuration
PORT=3002

# Postman API Configuration (Optional - for automated collection updates)
POSTMAN_API_KEY=your-postman-api-key
POSTMAN_COLLECTION_ID=5b21a5b0-891b-488e-84f3-dfadc79ef937

# To get your Postman API key:
# 1. Go to https://postman.co/settings/me/api-keys
# 2. Generate a new API key
# 3. Copy the key and paste it above
#
# The collection ID is already set to the NWCA Production API collection

# EmailJS Configuration (for backend-sent emails — daily broken-mockups digest)
# EMAILJS_SERVICE_ID:           same service ID used by the frontend
# EMAILJS_PUBLIC_KEY:           same public key used by the frontend
# EMAILJS_PRIVATE_KEY:          NEW — backend-only. EmailJS → Account → Security → Private Key
# EMAILJS_TEMPLATE_STEVE_DIGEST: ID of the template that accepts broken_count,
#                               scan_date, records_html, dashboard_link params
# STEVE_EMAIL:                  defaults to steve@nwcustomapparel.com
# SITE_ORIGIN:                  defaults to https://www.teamnwca.com (used in digest links)
# ADMIN_KEY_DIGEST:             any strong secret; protects POST /api/art-requests/broken-mockups/send-digest
EMAILJS_SERVICE_ID=service_jgrave3
EMAILJS_PUBLIC_KEY=your-emailjs-public-key
EMAILJS_PRIVATE_KEY=your-emailjs-private-key
EMAILJS_TEMPLATE_STEVE_DIGEST=template_xxxxxxxx
STEVE_EMAIL=steve@nwcustomapparel.com
SITE_ORIGIN=https://www.teamnwca.com
ADMIN_KEY_DIGEST=generate-a-strong-secret